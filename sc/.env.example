# Deployer wallet private key
PRIVATE_KEY=

# ECDSA signer address for score verification
SIGNER_ADDRESS=

# Dev treasury address — receives 10% rake from Duel/Royale rounds
DEV_TREASURY=

# Backend signer EOA — authorized to call resolveRound() and refundStake()
BACKEND_SIGNER=

# Monad Testnet RPC
RPC_URL=https://testnet-rpc.monad.xyz

# Optional: initial Solo Reserve Pool seed amount (in token units, e.g., 500000000 = 500 mUSDC)
# If not set, Solo mode will not work until reserve is manually seeded
INITIAL_RESERVE=100000000000